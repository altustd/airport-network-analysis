    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig-degree-dist\n",
        "#| fig-cap: Degree distribution of the US airport network on a log-log scale. A power-law fit to the complementary CDF is overlaid.\n",
        "\n",
        "degrees = sorted([d for _, d in Gcc.degree()], reverse=True)\n",
        "degree_series = pd.Series(degrees)\n",
        "\n",
        "# CCDF\n",
        "deg_vals = np.arange(1, max(degrees) + 1)\n",
        "ccdf = np.array([(degree_series >= k).mean() for k in deg_vals])\n",
        "mask = ccdf > 0\n",
        "\n",
        "# OLS fit on log-log\n",
        "log_k = np.log10(deg_vals[mask])\n",
        "log_p = np.log10(ccdf[mask])\n",
        "slope, intercept, r, p_val, _ = stats.linregress(log_k, log_p)\n",
        "gamma = -slope  # P(k) ~ k^-gamma  →  CCDF ~ k^-(gamma-1)\n",
        "fit_line = 10 ** (intercept + slope * log_k)\n",
        "\n",
        "fig_deg = go.Figure()\n",
        "fig_deg.add_trace(go.Scatter(\n",
        "    x=deg_vals[mask], y=ccdf[mask],\n",
        "    mode=\"markers\",\n",
        "    marker=dict(color=\"#1f77b4\", size=6, opacity=0.7),\n",
        "    name=\"Empirical CCDF\",\n",
        "))\n",
        "fig_deg.add_trace(go.Scatter(\n",
        "    x=deg_vals[mask], y=fit_line,\n",
        "    mode=\"lines\",\n",
        "    line=dict(color=\"#d62728\", width=2, dash=\"dash\"),\n",
        "    name=f\"Power-law fit (γ ≈ {gamma:.2f})\",\n",
        "))\n",
        "fig_deg.update_layout(\n",
        "    xaxis=dict(type=\"log\", title=\"Degree k\"),\n",
        "    yaxis=dict(type=\"log\", title=\"P(K ≥ k)\"),\n",
        "    title=\"Degree Distribution (Complementary CDF, log-log)\",\n",
        "    legend=dict(x=0.02, y=0.05),\n",
        "    template=\"plotly_white\",\n",
        ")\n",
        "fig_deg.show()"
      ],
      "id": "fig-degree-dist",
