        "#| label: load-data\n",
        "\n",
        "CACHE = Path(\"data/processed/airport_network.pkl\")\n",
        "\n",
        "if CACHE.exists():\n",
        "    with open(CACHE, \"rb\") as f:\n",
        "        data = pickle.load(f)\n",
        "    G_full   = data[\"G_full\"]\n",
        "    airports = data[\"airports\"]\n",
        "    routes   = data[\"routes\"]\n",
        "else:\n",
        "    airport_cols = [\n",
        "        \"id\", \"name\", \"city\", \"country\", \"iata\", \"icao\",\n",
        "        \"lat\", \"lon\", \"altitude\", \"timezone\", \"dst\", \"tz\", \"type\", \"source\"\n",
        "    ]\n",
        "    route_cols = [\n",
        "        \"airline\", \"airline_id\", \"src\", \"src_id\",\n",
        "        \"dst\", \"dst_id\", \"codeshare\", \"stops\", \"equipment\"\n",
        "    ]\n",
        "\n",
        "    airports = pd.read_csv(\n",
        "        \"https://raw.githubusercontent.com/jpatokal/openflights/master/data/airports.dat\",\n",
        "        header=None, names=airport_cols, na_values=\"\\\\N\", encoding=\"utf-8\"\n",
        "    )\n",
        "    routes_raw = pd.read_csv(\n",
        "        \"https://raw.githubusercontent.com/jpatokal/openflights/master/data/routes.dat\",\n",
        "        header=None, names=route_cols, na_values=\"\\\\N\", encoding=\"utf-8\"\n",
        "    )\n",
        "\n",
        "    # US airports only\n",
        "    us_airports = airports[airports[\"country\"] == \"United States\"].copy()\n",
        "    us_iata = set(us_airports[\"iata\"].dropna())\n",
        "\n",
        "    # US domestic nonstop routes\n",
        "    routes = routes_raw[\n",
        "        routes_raw[\"src\"].isin(us_iata) &\n",
        "        routes_raw[\"dst\"].isin(us_iata) &\n",
        "        (routes_raw[\"stops\"] == 0)\n",
        "    ].copy()\n",
        "\n",
        "    # Build undirected graph\n",
        "    G_full = nx.from_pandas_edgelist(\n",
        "        routes, source=\"src\", target=\"dst\", create_using=nx.Graph()\n",
        "    )\n",
        "\n",
        "    # Attach geographic attributes\n",
        "    airport_dict = (\n",
        "        us_airports.dropna(subset=[\"iata\"])\n",
        "        .set_index(\"iata\")[[\"name\", \"city\", \"lat\", \"lon\"]]\n",
        "        .to_dict(\"index\")\n",
        "    )\n",
        "    nx.set_node_attributes(G_full, airport_dict)\n",
        "\n",
        "    Path(\"data/processed\").mkdir(parents=True, exist_ok=True)\n",
        "    with open(CACHE, \"wb\") as f:\n",
        "        pickle.dump({\"G_full\": G_full, \"airports\": us_airports, \"routes\": routes}, f)\n",
        "\n",
        "# Work on the largest connected component (LCC) for path-length metrics\n",
        "Gcc = G_full.subgraph(\n",
        "    max(nx.connected_components(G_full), key=len)\n",
        ").copy()\n",
        "\n",
        "n     = Gcc.number_of_nodes()\n",
        "m     = Gcc.number_of_edges()\n",
        "k_avg = 2 * m / n\n",
        "\n",
        "# Compute centrality once; reused across all cells\n",
        "degree_cent  = dict(Gcc.degree())\n",
        "between_cent = nx.betweenness_centrality(Gcc, normalized=True, k=min(200, n))"
      ],
